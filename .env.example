# ─────────────────────────────────────────────────────────────────────────
# Umer Designs — Backend (Nest.js) environment variables
# Copy to .env and fill in real values. Never commit the real .env file.
# ─────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# Postgres connection string. Hosted Postgres (Neon/Supabase) recommended —
# https://neon.tech or https://supabase.com, both have a free tier.
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://user:password@host/umer_designs?sslmode=require

# ── JWT (access + refresh) ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-random-64-char-hex-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-random-64-char-hex-string
JWT_REFRESH_EXPIRES_IN_DAYS=7

# ── Internal BFF <-> backend attestation ────────────────────────────────────
# Shared with the frontend's INTERNAL_HMAC_SECRET (must match exactly).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Rotate via `npm run script:internal-secret:rotate` (see README).
INTERNAL_HMAC_SECRET=replace-with-a-random-64-char-hex-string
INTERNAL_HMAC_WINDOW_MS=60000

# Only the frontend's own origin should ever be allowed here.
CORS_ALLOWED_ORIGIN=http://localhost:3000

BCRYPT_SALT_ROUNDS=12

# ── Rate limiting ────────────────────────────────────────────────────────
AUTH_RATE_LIMIT_TTL_MS=60000
AUTH_RATE_LIMIT_LIMIT=10
PAYMENT_RATE_LIMIT_TTL_MS=60000
PAYMENT_RATE_LIMIT_LIMIT=20
DEFAULT_RATE_LIMIT_TTL_MS=60000
DEFAULT_RATE_LIMIT_LIMIT=120

# ── Cloudinary (file storage) ───────────────────────────────────────────────
# Optional — the app boots without these; upload/download endpoints return a
# clean 503 until they're set. From https://cloudinary.com/console (free tier).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_SIGNED_URL_TTL_SECONDS=300

# ── Stripe (payments) ────────────────────────────────────────────────────
# Optional — same graceful-degradation pattern as Cloudinary. Use a test-mode
# secret key (sk_test_...) from https://dashboard.stripe.com/test/apikeys.
# The webhook *signing* secret lives on the frontend (see its .env.example) —
# this backend never receives the raw Stripe webhook, only the BFF's verified
# forward. See the architecture guide for why.
STRIPE_SECRET_KEY=

# ── SMTP (transactional email via Resend/Brevo/etc.) ────────────────────────
# Optional — the app boots and in-app notifications still work without this;
# only the email side of each notification is skipped (logged, not thrown).
# Resend: smtp.resend.com, port 587, user "resend", pass = your API key.
# Brevo: smtp-relay.brevo.com, port 587, user = your Brevo login email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Umer Designs <no-reply@yourdomain.com>"

# Optional: where "new order / new request / new meeting" admin-alert emails go.
ADMIN_NOTIFY_EMAIL=

# ── Referral program ─────────────────────────────────────────────────────
# Flat credit (in cents) a referrer earns on their referred user's first paid order.
REFERRAL_REWARD_CENTS=3000
